#!/usr/bin/env bash
set -euo pipefail

repo="${LASH_DEV_REPO:-/workspace/code/lash}"
target_dir="${CARGO_TARGET_DIR:-${repo}/target}"

if [[ "${target_dir}" != /* ]]; then
  target_dir="${repo}/${target_dir}"
fi

binary="${target_dir}/debug/lash"

if [[ "${LASH_SKIP_REBUILD:-}" != "1" ]]; then
  cargo build -q --manifest-path "${repo}/Cargo.toml" -p lash-cli --bin lash
fi

exec "${binary}" "$@"
