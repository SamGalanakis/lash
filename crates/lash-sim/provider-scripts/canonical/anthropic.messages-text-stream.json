{
  "schema": "lash.provider-wire-script.v1",
  "name": "anthropic.messages-text-stream",
  "provider_kind": "anthropic",
  "endpoint": {
    "method": "POST",
    "path": "/v1/messages"
  },
  "request_match": {
    "body": {
      "model": { "equals": "claude-sonnet-4-20250514" },
      "stream": { "equals": true },
      "messages": { "contains_role": "user" }
    },
    "headers": {
      "x-api-key": { "present": true },
      "anthropic-version": { "present": true },
      "anthropic-beta": { "contains": "fine-grained-tool-streaming" },
      "content-type": { "contains": "application/json" }
    }
  },
  "timeline": [
    {
      "at": 10,
      "event": "response_start",
      "status": 200,
      "headers": [
        { "name": "content-type", "value": "text/event-stream; charset=utf-8" },
        { "name": "request-id", "value": "req-anthropic-text" }
      ]
    },
    {
      "at": 20,
      "event": "sse",
      "data": "{\"type\":\"message_start\",\"message\":{\"id\":\"msg_1\",\"type\":\"message\",\"role\":\"assistant\",\"model\":\"claude-sonnet-4-20250514\",\"content\":[],\"stop_reason\":null,\"usage\":{\"input_tokens\":7,\"output_tokens\":0}}}"
    },
    {
      "at": 21,
      "event": "sse",
      "data": "{\"type\":\"content_block_start\",\"index\":0,\"content_block\":{\"type\":\"text\",\"text\":\"\"}}"
    },
    {
      "at": 22,
      "event": "sse",
      "data": "{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"Anthropic scripted answer.\"}}"
    },
    {
      "at": 23,
      "event": "sse",
      "data": "{\"type\":\"content_block_stop\",\"index\":0}"
    },
    {
      "at": 24,
      "event": "sse",
      "data": "{\"type\":\"message_delta\",\"delta\":{\"stop_reason\":\"end_turn\"},\"usage\":{\"output_tokens\":4}}"
    },
    {
      "at": 25,
      "event": "sse",
      "data": "{\"type\":\"message_stop\"}"
    },
    { "at": 26, "event": "end" }
  ],
  "expected_provider": {
    "terminal_reason": "stop",
    "text": "Anthropic scripted answer."
  }
}
