{
  "schema": "lash.provider-wire-script.v1",
  "name": "google.stream-generate-content-text-stream",
  "provider_kind": "google_oauth",
  "endpoint": {
    "method": "POST",
    "path": "/v1internal:streamGenerateContent"
  },
  "request_match": {
    "body": {
      "model": { "equals": "gemini-3.1-pro-preview" },
      "request.contents[0].role": { "equals": "user" },
      "request.contents[0].parts[0].text": { "contains": "answer directly" },
      "request.sessionId": { "equals": "session-1" },
      "project": { "equals": "project-1" }
    },
    "headers": {
      "authorization": { "present": true },
      "content-type": { "contains": "application/json" }
    }
  },
  "timeline": [
    {
      "at": 10,
      "event": "response_start",
      "status": 200,
      "headers": [
        { "name": "content-type", "value": "text/event-stream; charset=utf-8" },
        { "name": "x-request-id", "value": "req-google-stream" }
      ]
    },
    {
      "at": 20,
      "event": "sse",
      "data": "{\"response\":{\"candidates\":[{\"content\":{\"parts\":[{\"text\":\"Google scripted answer.\"}]}}],\"usageMetadata\":{\"promptTokenCount\":6,\"candidatesTokenCount\":3,\"thoughtsTokenCount\":1}}}"
    },
    {
      "at": 21,
      "event": "sse",
      "data": "{\"response\":{\"candidates\":[{\"finishReason\":\"STOP\"}],\"usageMetadata\":{\"promptTokenCount\":6,\"candidatesTokenCount\":3,\"thoughtsTokenCount\":1}}}"
    },
    { "at": 22, "event": "end" }
  ],
  "expected_provider": {
    "terminal_reason": "stop",
    "text": "Google scripted answer."
  }
}
