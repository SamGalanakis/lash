{
  "schema": "lash.provider-wire-script.v1",
  "name": "google.generate-content-rate-limit-429",
  "provider_kind": "google_oauth",
  "endpoint": {
    "method": "POST",
    "path": "/v1internal:generateContent"
  },
  "request_match": {
    "body": {
      "model": { "equals": "gemini-3.1-pro-preview" },
      "request.contents[0].role": { "equals": "user" },
      "project": { "equals": "project-1" }
    },
    "headers": {
      "authorization": { "present": true },
      "content-type": { "contains": "application/json" }
    }
  },
  "timeline": [
    {
      "at": 10,
      "event": "http_error",
      "status": 429,
      "headers": [
        { "name": "content-type", "value": "application/json" },
        { "name": "retry-after", "value": "5" },
        { "name": "x-request-id", "value": "req-google-rate-limit" }
      ],
      "body": "{\"error\":{\"message\":\"quota exhausted\",\"status\":\"RESOURCE_EXHAUSTED\"}}"
    }
  ],
  "expected_provider": {
    "terminal_reason": "provider_error"
  }
